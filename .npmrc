# Supply-chain hardening — applies to local installs AND CI (npm ci reads this file).
# Refuse package versions younger than 14 days (older npm versions ignore this key with a warning).
min-release-age=14

# Block lifecycle scripts (postinstall/preinstall). The build needs none;
# Playwright browsers are installed explicitly via `npx playwright install`.
ignore-scripts=true

# Block git-URL dependencies, direct and transitive.
allow-git=none
